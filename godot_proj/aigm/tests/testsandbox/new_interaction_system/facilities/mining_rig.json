{
  "id": "mining_rig",
  "name": "自动挖矿机",
  "category": "work",
  "tags": ["work", "passive_income", "investment", "risk", "automated"],
  "services": [
    {
      "type": "mining_operation",
      "needs": ["money", "investment", "passive_income"],
      "duration_sec": 180,
      "effects": [
        { "stat": "money", "operation": "add", "value": 120 },
        { "stat": "energy", "operation": "add", "value": -5 }
      ],
      "cost": { "money": 50 },
      "constraints": {
        "max_concurrent_users": 1,
        "can_interrupt": true,
        "upfront_cost": 50
      }
    }
  ],
  "physical": {
    "interact_radius": 60,
    "sprite": "mining_machine.png"
  },
  "ai_controller": "res://new_interaction_system/controllers/passive_income_controller.gd"
}
